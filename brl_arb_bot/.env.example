# Copie para .env e preencha — NUNCA suba o .env para o GitHub

# Token do bot Telegram (obtido no @BotFather)
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Seu Telegram ID de administrador (obtenha em @userinfobot)
ADMIN_TELEGRAM_ID=seu_id_aqui

# Envia mensagem ao admin a cada restart com build e horario.
BOOT_NOTIFY_ADMIN=true

# Segurança do cofre (recomendado em produção)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_MASTER_KEY=
VAULT_REQUIRE_ENV_KEY=true

# 1inch API Key (gratuita em dev.1inch.io — opcional mas recomendada)
ONEINCH_API_KEY=

# Slippage base no 1inch (em %) e tentativas progressivas para reduzir revert.
ONEINCH_SLIPPAGE=1
SWAP_SLIPPAGE_STEPS=0.5,1,2,3

# Approve automático quando faltar allowance para swap ERC-20
AUTO_APPROVE_ERC20=true
APPROVE_MAX_UINT=true
APPROVE_PRIORITY_FEE_WEI=1500000000

# 0x API Key (opcional, melhora limite de rate e estabilidade)
ZEROX_API_KEY=

# Jumper / Li.Fi API Key (opcional)
LIFI_API_KEY=

# Ordem de tentativa das DEXs de execução (separadas por vírgula)
DEX_PRIORITY=1inch,zerox,jumper,oku,llama

# Configuração Oku Trade (Canoe)
OKU_API_BASE=https://canoe.v2.icarus.tools
OKU_MARKET_ID=zeroex
OKU_SLIPPAGE_BPS=50

# Adapter configurável para LlamaSwap (se tiver endpoint privado/público)
LLAMASWAP_QUOTE_URL=
LLAMASWAP_SLIPPAGE=0.5

# Slippage para Jumper/Li.Fi
LIFI_SLIPPAGE=0.5

# Robustez de execução on-chain
TX_GAS_MULTIPLIER=1.15
SWAP_RECEIPT_TIMEOUT_SEC=120
